{
  "font": {
    "family": {
      "sans": "\"SF Pro\", \"SF Pro Text\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
    },
    "weight": {
      "regular": 400,
      "medium": 500
    },
    "size": {
      "xs": "12px",
      "sm": "13px",
      "md": "14px",
      "lg": "16px",
      "xl": "18px",
      "2xl": "24px"
    },
    "baseSize": "13px",
    "maxSize": "24px"
  },
  "color": {
    "text": {
      "subtle": "#7f7f7f",
      "default": "#5d5d5d",
      "strong": "#292929"
